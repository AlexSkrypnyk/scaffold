#;< PHP
#;< PHP_PHAR
/.build
#;> PHP_PHAR
/.phpunit.cache
/composer.lock
/vendor
/vendor-bin
#;> PHP
#;< NODEJS
/node_modules
/package-lock.json
/yarn.lock
#;> NODEJS

# Code coverage and test logs.
/.logs

# Temporary AI agent and developer artifacts (plans, scratch output, reports).
/.artifacts/

