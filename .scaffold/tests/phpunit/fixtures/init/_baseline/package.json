{
    "name": "@yodashut/force-crystal",
    "version": "__VERSION__",
    "description": "Provides force-crystal functionality.",
    "license": "GPL-3.0-or-later",
    "author": {
        "name": "Luke Skywalker",
        "email": "force-crystal@yodashut.com",
        "url": "https://yodashut.com"
    },
    "contributors": [],
    "repository": "github:yodashut/force-crystal",
    "bugs": "https://github.com/yodashut/force-crystal/issues",
    "directories": {
        "test": "tests"
    },
    "bin": {
        "force-crystal": "./nodejs-script"
    },
    "scripts": {
        "lint": "eslint nodejs-script tests/nodejs eslint.config.js && prettier --check nodejs-script \"tests/nodejs/**/*.js\" eslint.config.js",
        "lint-fix": "eslint --fix nodejs-script tests/nodejs eslint.config.js && prettier --write nodejs-script \"tests/nodejs/**/*.js\" eslint.config.js",
        "test": "node --test tests/nodejs/*.test.js",
        "test-coverage": "c8 node --test tests/nodejs/*.test.js",
        "reset": "rm -Rf node_modules package-lock.json"
    },
    "engines": {
        "npm": "__VERSION__",
        "node": "__VERSION__"
    },
    "dependencies": {},
    "devDependencies": {
        "@eslint/js": "__VERSION__",
        "c8": "__VERSION__",
        "eslint": "__VERSION__",
        "eslint-config-prettier": "__VERSION__",
        "globals": "__VERSION__",
        "prettier": "__VERSION__"
    },
    "prettier": {
        "singleQuote": true,
        "overrides": [
            {
                "files": "nodejs-script",
                "options": {
                    "parser": "babel"
                }
            }
        ]
    }
}
